# API (cmd/api)
PORT=8080
APP_ENV=development
# Postgres connection string (required for API). On startup the API runs db/migrations/*.sql in order.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taskmanagerv2?sslmode=disable
# HS256 signing secret (required outside development; min ~32 random bytes in production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
# Auth brute-force guard: max POSTs per IP per minute to /auth/register, /auth/login, /auth/refresh.
# When unset: unlimited in development; in APP_ENV=production defaults to 60. Override explicitly in prod.
# AUTH_RATE_LIMIT_PER_MINUTE=120
# Allowed browser origin for CORS (set to your Pages URL in staging/prod)
CORS_ORIGIN=http://localhost:5173

# Web (Vite) — prefix VITE_ exposes to the client
VITE_API_BASE_URL=http://localhost:8080
# Cloudflare Pages: VITE_API_URL is the full API root (e.g. Go: https://host — paths add /api/v1/...;
# Supabase Edge root: https://<ref>.supabase.co/functions/v1 — client omits extra /api/v1).
# VITE_API_URL=https://nfbquxfnsprwjsehhnvq.supabase.co/functions/v1
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# CLI (cli/) — API root for task routes (OpenAPI: /api/v1; Supabase Edge: /functions/v1)
TASKMANAGER_API_URL=http://localhost:8080/api/v1
# TASKMANAGER_TOKEN=   # optional Bearer JWT
