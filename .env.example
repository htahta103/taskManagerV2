# API (cmd/api)
PORT=8080
APP_ENV=development
# Postgres connection string (required for API)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taskmanagerv2?sslmode=disable
# HS256 signing secret (required outside development; min ~32 random bytes in production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
# Allowed browser origin for CORS (set to your Pages URL in staging/prod)
CORS_ORIGIN=http://localhost:5173

# Web (Vite) — prefix VITE_ exposes to the client
VITE_API_BASE_URL=http://localhost:8080
